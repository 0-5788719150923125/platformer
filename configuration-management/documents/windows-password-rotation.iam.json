{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowParameterStoreWrite",
      "Effect": "Allow",
      "Action": [
        "ssm:PutParameter"
      ],
      "Resource": [
        "arn:aws:ssm:*:${aws_account_id}:parameter${parameter_store_prefix}/*"
      ]
    },
    {
      "Sid": "AllowKMSForParameterStore",
      "Effect": "Allow",
      "Action": [
        "kms:Decrypt",
        "kms:Encrypt",
        "kms:GenerateDataKey"
      ],
      "Resource": ["*"],
      "Condition": {
        "StringEquals": {
          "kms:ViaService": [
            "ssm.${region}.amazonaws.com"
          ]
        }
      }
    }
  ]
}
